# ==========================================================
# CREDENCIALES TOA
# ==========================================================
TOA_USERNAME=mgi.corp   
TOA_PASSWORD=Gtd.12345

# ==========================================================
# RUTAS DENTRO DEL CONTENEDOR
# Los archivos del host deben quedar en ./data/
# ==========================================================
RUTA_INPUTS_TOA=data\InputsTOA.xlsx
RUTA_EXC_MONITOREO=/data/toa/toa_output/Monitoreo.xlsx
RUTA_BBDD_TOA=/data/toa/toa_output/BBDD_TOA.xlsx
TOA_RUNS_DIR=/data/toa/toa_runs
DOWNLOAD_DIR=/data/toa/toa_runs/downloads

# ==========================================================
# NAVEGADOR EN DOCKER
# ==========================================================
TOA_BROWSER_CHANNEL=chromium
TOA_HEADLESS=true
TOA_SLOW_MO_MS=0

# ==========================================================
# PLANIFICADOR
# Ejecuta al levantar y luego a las horas :00 y :30.
# RUN_ONCE=true sirve para probar una única ejecución.
# ==========================================================
TZ=America/Santiago
SCHEDULER_INTERVAL_MINUTES=30
SCHEDULER_HEARTBEAT_SECONDS=60
RUN_ON_START=true
RUN_ONCE=false
STOP_ON_ERROR=false
HEALTHCHECK_MAX_AGE_MINUTES=40

# ==========================================================
# RANGO DE FECHAS
# ==========================================================
TOA_DAYS_BACK=3
TOA_DAYS_FORWARD=30

# ==========================================================
# API TOA
# Primera prueba: deja TOA_API_DRY_RUN=true.
# Producción: cambia a false después de validar los logs.
# ==========================================================
TOA_API_ENABLED=true
#TOA_API_EMPTY_URL=http://216.155.78.14/api/toa/vaciar-tabla-toa
#TOA_API_CREATE_URL=http://216.155.78.14/api/toa/crear-cita-toa
TOA_API_BATCH_SIZE=300
TOA_API_TIMEOUT=120
TOA_API_BATCH_DELAY_SECONDS=0.2
TOA_API_EMPTY_RETRIES=3
TOA_API_CREATE_RETRIES=2
TOA_API_RETRY_WAIT_SECONDS=2
TOA_API_PAYLOAD_KEY=

TOA_API_DRY_RUN=false
TOA_API_ALLOW_EMPTY_SNAPSHOT=false

TOA_API_TOKEN=
TOA_API_KEY=

# ==========================================================
# SALIDAS OPCIONALES
# ==========================================================
PG_ENABLED=false
CLEAN_RUN_MANIFEST=false

# ==========================================================
# PRUEBA AISLADA
# Mantener false para el flujo completo programado.
# ==========================================================
TOA_TEST_ONE_DOWNLOAD=false
TOA_API_SEND_ENABLED=false
